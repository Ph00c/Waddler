{
  "manifest_version": 3,
  "name": "Waddler",
  "version": "1.0.0",
  "description": "A cute app for those long distance couples.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open My Extension"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ]
}
